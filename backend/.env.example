LOG_LEVEL=info
LOG_FORMAT=simple
LOG_SLOW_REQUEST_THRESHOLD=500
LOG_SKIP_PATHS=/health

# Authentication Configuration
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-refresh-secret-key-minimum-32-characters
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Rate limiting configuration
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_STRICT_TTL=60000
RATE_LIMIT_STRICT_MAX=10

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=chioma_db
PAYMENT_METADATA_SECRET=change_me

# AWS S3 Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
PAYMENT_GATEWAY=mock
PAYSTACK_SECRET_KEY=erhrgehr
FLUTTERWAVE_SECRET_KEY=egerherhgd
PAYMENT_GATEWAY_TIMEOUT_MS=10000

# Application Configuration
NODE_ENV=development
PORT=3000

# Admin Seed Configuration
ADMIN_DEFAULT_EMAIL=admin@chioma.local
ADMIN_DEFAULT_FIRST_NAME=System
ADMIN_DEFAULT_LAST_NAME=Administrator
ADMIN_AUTO_GENERATE_PASSWORD=true

# Escrow Contract Configuration
ESCROW_CONTRACT_ID=<your-escrow-contract-id>
DEFAULT_ARBITER_ADDRESS=<default-arbiter-stellar-address>

# Dispute Resolution Contract Configuration
DISPUTE_CONTRACT_ID=<your-dispute-contract-id>
MIN_VOTES_REQUIRED=3

# Health Check Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HEALTH_CHECK_TIMEOUT=5000
MEMORY_WARNING_THRESHOLD=536870912
MEMORY_ERROR_THRESHOLD=1073741824

# Email Configuration (for password reset emails)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@chioma.app

# Frontend Configuration (for password reset / email verification links)
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Stellar/Soroban Configuration
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CHIOMA_CONTRACT_ID=
ESCROW_CONTRACT_ID=
RENT_OBLIGATION_CONTRACT_ID=
STELLAR_ADMIN_SECRET_KEY=
DEFAULT_ARBITER_ADDRESS=
SERVER_STELLAR_SECRET=herherg
STELLAR_SERVER_SECRET_KEY=rehger

# IPFS/Pinata Configuration
PINATA_JWT=rherrge
PINATA_GATEWAY=gateway.pinata.cloud

# Anchor Configuration
ANCHOR_API_URL=https://api.anchor-provider.com
ANCHOR_API_KEY=your_api_key
ANCHOR_USDC_ASSET=USDC:GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
SUPPORTED_FIAT_CURRENCIES=USD,EUR,GBP,NGN

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For Upstash (serverless Redis), use these instead:
# REDIS_URL=https://your-upstash-redis-url.upstash.io
# REDIS_TOKEN=your-upstash-token
REDIS_USERNAME=default
REDIS_TLS=false

# Bull Job Queue Configuration
BULL_QUEUE_EMAIL_ATTEMPTS=3
BULL_QUEUE_EMAIL_BACKOFF_DELAY=2000
BULL_QUEUE_DOCUMENTS_ATTEMPTS=3
BULL_QUEUE_DOCUMENTS_BACKOFF_DELAY=3000
BULL_QUEUE_BLOCKCHAIN_ATTEMPTS=5
BULL_QUEUE_BLOCKCHAIN_BACKOFF_DELAY=5000
BULL_QUEUE_DATA_SYNC_ATTEMPTS=3
BULL_QUEUE_DATA_SYNC_BACKOFF_DELAY=2000

# Sentry Configuration
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Security Configuration
SECURITY_ENCRYPTION_KEY=YOUR_SECURITY_ENCRYPTION_KEY
SECURITY_CSRF_ENABLED=false
SECURITY_SESSION_SECRET=your-session-secret-minimum-32-characters-long

# Encryption Configuration (AES-256-GCM)
# Generate a 32-byte base64 key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY_BASE64=YOUR_32_BYTE_BASE64_ENCRYPTION_KEY_HERE
# Or use multiple keys for rotation (JSON array, newest first):
# ENCRYPTION_KEYS=["new_key_base64","old_key_base64"]

# Monitoring Configuration
LOG_LEVEL=debug
LOG_FORMAT=simple
LOG_SLOW_REQUEST_THRESHOLD=500
LOG_SKIP_PATHS=/health
LOG_MAX_FILES=7d
LOG_MAX_SIZE=10m
METRICS_ENABLED=true
TRACING_ENABLED=true

# Response Time Tracking
RESPONSE_TIME_ENABLED=true
RESPONSE_TIME_SLOW_THRESHOLD_MS=500
RESPONSE_TIME_WINDOW_SECONDS=60
RESPONSE_TIME_BUFFER_SIZE=1000

# Error Notification & Escalation
ERROR_NOTIFICATION_ENABLED=false
ALERT_ONCALL_EMAIL=oncall@chioma.app
ALERT_ESCALATION_EMAIL=platform-leads@chioma.app
ALERT_MANAGEMENT_EMAIL=
SLACK_ALERT_WEBHOOK_URL=
ALERT_ESCALATION_MINUTES=15
ALERT_ESCALATION_TIER2_MINUTES=30
ALERT_WEBHOOK_SECRET=change-me-alert-webhook-secret

# Dead Letter Queue (failed Bull jobs)
DEAD_LETTER_QUEUE_ENABLED=true
DEAD_LETTER_RETENTION_DAYS=30

# Database Connection Monitoring
DB_MONITORING_ENABLED=true
DB_POOL_WARNING_PERCENT=70
DB_POOL_CRITICAL_PERCENT=90
DB_QUERY_TIME_WARNING_MS=500
DB_QUERY_TIME_CRITICAL_MS=2000

# Database Index Review
DB_INDEX_UNUSED_MIN_SCANS=10
DB_INDEX_UNUSED_MIN_SIZE_MB=10

# API Versioning
API_LATEST_VERSION=v1
API_DEPRECATION_ENABLED=true
