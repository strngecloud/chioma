{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "pnpm exec eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --forceExit",
    "test:leaks": "jest --detectOpenHandles --forceExit",
    "test:mutation": "stryker run",
    "test:mutation:fast": "stryker run --mutate src/common/utils/*.ts",
    "test:contract": "jest --config ./test/jest-contract.json --forceExit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "DB_TYPE=postgres jest --config ./test/jest-e2e.json --runInBand",
    "ci": "pnpm run lint && npx prettier --check \"src/**/*.ts\" \"test/**/*.ts\" && pnpm exec tsc --noEmit && pnpm run test && pnpm run test:cov",
    "ci:local": "./scripts/ci-local.sh",
    "openapi:generate": "OPENAPI_GENERATE=true ts-node -r tsconfig-paths/register scripts/generate-openapi.ts",
    "perf": "node scripts/performance-benchmark.mjs",
    "perf:enhanced": "node scripts/performance-benchmark-enhanced.mjs",
    "perf:load": "node scripts/load-test.mjs",
    "perf:comprehensive": "pnpm run test:e2e -- --testPathPattern=performance-comprehensive",
    "perf:local": "node scripts/load-test.mjs local --report-format=html",
    "perf:staging": "node scripts/load-test.mjs staging --report-format=html",
    "perf:ci": "node scripts/performance-benchmark-enhanced.mjs --report-format=json",
    "test:chaos": "pnpm run test:e2e -- --testPathPattern=chaos-resilience --forceExit",
    "sdk:generate": "node scripts/sdk-generate.mjs",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- -d src/database/data-source.ts",
    "migration:create": "npm run typeorm migration:create --",
    "migration:run": "npm run typeorm migration:run -- -d src/database/data-source.ts",
    "migration:run:safe": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d ./dist/src/database/data-source.js",
    "migration:show": "npm run typeorm migration:show -- -d src/database/data-source.ts",
    "migration:show:safe": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts show",
    "migration:show:prod": "node ./node_modules/typeorm/cli.js migration:show -d ./dist/src/database/data-source.js",
    "migration:revert": "npm run typeorm migration:revert -- -d src/database/data-source.ts",
    "migration:revert:safe": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts revert",
    "migration:revert:prod": "node ./node_modules/typeorm/cli.js migration:revert -d ./dist/src/database/data-source.js",
    "migration:verify-rollback": "bash ./scripts/test-migration-rollback.sh",
    "migration:rollback-to": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts revert --to",
    "migration:dry-run": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts run --dry-run",
    "migration:list": "ts-node -r tsconfig-paths/register src/database/migration-runner.ts show",
    "db:index-review": "ts-node -r tsconfig-paths/register scripts/db-index-review.ts",
    "db:index-review:all": "ts-node -r tsconfig-paths/register scripts/db-index-review.ts --all",
    "db:monitor:health": "ts-node -r tsconfig-paths/register scripts/db-monitor-snapshot.ts",
    "kyc:migrate": "ts-node -r tsconfig-paths/register scripts/kyc-data-migration.ts migrate",
    "kyc:migrate:verify": "ts-node -r tsconfig-paths/register scripts/kyc-data-migration.ts verify",
    "kyc:migrate:rollback": "ts-node -r tsconfig-paths/register scripts/kyc-data-migration.ts rollback",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed-runner.ts",
    "seed:currencies": "ts-node src/database/seeds/seed-currencies.ts",
    "seed:data": "ts-node -r tsconfig-paths/register src/database/seed-runner.ts",
    "seed:test": "NODE_ENV=test ts-node -r tsconfig-paths/register src/database/seeds/seed-test-db.ts",
    "db:consistency": "ts-node -r tsconfig-paths/register src/database/consistency-checker.ts",
    "db:perf-report": "ts-node -r tsconfig-paths/register scripts/db-performance-report.ts",
    "db:backup": "./scripts/backup-db.sh",
    "db:restore": "./scripts/db-restore.sh",
    "seed:admin": "ts-node src/commands/index.ts admin",
    "seed:admin:prod": "NODE_ENV=production ts-node src/commands/index.ts admin --force",
    "seed:agent": "ts-node src/commands/index.ts agent",
    "seed:agent:prod": "NODE_ENV=production ts-node src/commands/index.ts agent --force",
    "seed:tenant": "ts-node src/commands/index.ts tenant",
    "seed:tenant:prod": "NODE_ENV=production ts-node src/commands/index.ts tenant --force",
    "seed:landlord": "ts-node src/commands/index.ts landlord",
    "seed:landlord:prod": "NODE_ENV=production ts-node src/commands/index.ts landlord --force",
    "seed:all": "pnpm run seed:admin && pnpm run seed:agent && pnpm run seed:tenant && pnpm run seed:landlord",
    "seed:all:prod": "NODE_ENV=production pnpm run seed:admin:prod && pnpm run seed:agent:prod && pnpm run seed:tenant:prod && pnpm run seed:landlord:prod",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@elastic/elasticsearch": "^9.3.2",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/instrumentation-express": "^0.66.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/instrumentation-typeorm": "^0.18.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/nestjs": "^10.39.0",
    "@stellar/stellar-sdk": "^12.2.0",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.17.2",
    "pinata": "^2.5.3",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "stellar-hd-wallet": "^1.0.2",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "uuid": "^8.3.2",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/jest-json-schema": "^6.1.5",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.5",
    "@types/socket.io": "^3.0.2",
    "@types/speakeasy": "^2.0.9",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.11.7",
    "autocannon": "^7.14.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-json-schema": "^6.1.0",
    "minimatch": "^9.0.8",
    "minimist": "^1.2.8",
    "nock": "^14.0.15",
    "nopt": "^5.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^bcryptjs$": "<rootDir>/test/mocks/bcryptjs.ts",
      "^@nestjs/passport$": "<rootDir>/test/mocks/nestjs-passport.ts",
      "^@nestjs/terminus$": "<rootDir>/test/mocks/nestjs-terminus.ts",
      "^passport-jwt$": "<rootDir>/test/mocks/nestjs-passport.ts",
      "^passport$": "<rootDir>/test/mocks/nestjs-passport.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../test/setup-env.ts"
    ]
  },
  "overrides": {
    "tar": "^7.5.10",
    "minimatch": "^9.0.8",
    "serialize-javascript": "^7.0.3",
    "multer": "^2.1.1",
    "picomatch@<2.3.2": "^2.3.2",
    "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
