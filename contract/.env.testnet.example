# Testnet Contract IDs
# Generated after deployment - copy to .env.testnet and fill in values

# Main Rental Agreement Contract
CHIOMA_CONTRACT_ID=

# Dispute Resolution & Arbitration
DISPUTE_RESOLUTION_CONTRACT_ID=

# Security Deposit Escrow
ESCROW_CONTRACT_ID=

# Rent Payment Processing
PAYMENT_CONTRACT_ID=

# Agent Registration & Verification
AGENT_REGISTRY_CONTRACT_ID=

# Property Registration & Verification
PROPERTY_REGISTRY_CONTRACT_ID=

# Tokenized Rent Obligations (NFT)
RENT_OBLIGATION_CONTRACT_ID=

# User Profile Management
USER_PROFILE_CONTRACT_ID=

# Deployment Configuration
DEPLOYER_KEY=testnet-deployer
NETWORK=testnet
ADMIN_ADDRESS=

# Optional: Fee Configuration
PLATFORM_FEE_BPS=500
MIN_DISPUTE_VOTES=3

# Optional: Rate Limiting
RATE_LIMIT_DAILY=1000
RATE_LIMIT_COOLDOWN_SECONDS=60

# Optional: Monitoring
MONITOR_EVENTS=true
LOG_LEVEL=info
